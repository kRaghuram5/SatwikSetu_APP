# ============================================
# Agent Chiguru AI Platform — Environment Config
# ============================================

# PostgreSQL
POSTGRES_USER=agentchiguru
POSTGRES_PASSWORD=agentchiguru123
POSTGRES_DB=agentchiguru_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5532
DATABASE_URL=postgresql://agentchiguru:agentchiguru123@postgres:5432/agentchiguru_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092


# OpenAI (for AI Advisory RAG)
OPENAI_API_KEY=""
LLM_PROVIDER=openai  # Options: openai, ollama, mock

# Ollama (alternative LLM)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# JWT Auth
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Rate Limiting
RATE_LIMIT_PER_MINUTE=5

# Service URLs (internal Docker network)
DISEASE_DETECTION_URL=http://disease-detection:8001
AI_ADVISORY_URL=http://ai-advisory:8002
IRRIGATION_URL=http://irrigation:8003
MARKET_PRICE_URL=http://market-price:8004
NOTIFICATION_URL=http://notification:8005